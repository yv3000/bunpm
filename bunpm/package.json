{
  "name": "bunpm",
  "version": "1.0.0",
  "description": "Transparent npm wrapper that uses Bun under the hood for 10x faster installs",
  "main": "lib/wrapper.js",
  "bin": {
    "bunpm-install": "scripts/install.ps1",
    "bunpm-uninstall": "scripts/uninstall.ps1"
  },
  "scripts": {
    "install-wrapper": "powershell -ExecutionPolicy Bypass -File scripts/install.ps1",
    "uninstall-wrapper": "powershell -ExecutionPolicy Bypass -File scripts/uninstall.ps1"
  },
  "keywords": [
    "npm",
    "bun",
    "wrapper",
    "fast",
    "package-manager",
    "windows",
    "transparent"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": ""
  }
}
